            authLoadingLabel={flow.authLoadingLabel}
            syncStatus={flow.syncStatus}
            onLogin={flow.handleLogin}
            recoveryView={flow.recoveryView}
            recoveryMessage={flow.recoveryMessage}
            recoveryEmail={flow.recoveryEmail}
