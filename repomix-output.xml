  setAuthEmail,
  authPassword,
  setAuthPassword,
  authMode,
  setAuthMode,
  isLoading,
  authLoadingLabel,
  authMessage,
  syncStatus,
  onLogin,
  recoveryView,
  recoveryMessage,
  recoveryEmail,
  setRecoveryEmail,
  recoveryPassword,
  setRecoveryPassword,
  recoveryPasswordConfirm,
  setRecoveryPasswordConfirm,
  recoveryIsLoading,
