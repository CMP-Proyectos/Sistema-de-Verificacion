                    <div style={es.thumbnailMeta}>
                      <span>{index === 0 ? 'Principal' : `Imagen ${index + 1}`}</span>
                      <button type="button" onClick={() => onRemoveImage(image.id)} style={es.thumbnailDeleteBtn}>
