          type="password"
          placeholder="Ingrese su nueva contraseña"
          value={recoveryPassword}
          onChange={(event) => setRecoveryPassword(event.target.value)}
          style={styles.input}
          disabled={recoveryIsLoading}
        />
      </div>

      <div>
        <label style={styles.label}>Confirmar contraseña</label>
